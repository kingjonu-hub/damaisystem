# ── Variabel environment untuk PRODUKSI (Railway/Render) ──────────
# Salin nilai-nilai ini ke tab "Variables" di dashboard platform deploy Anda.
# JANGAN commit file .env asli (berisi secret) ke GitHub — file ini hanya
# acuan nama variabel yang dibutuhkan.

PORT=5000
NODE_ENV=production

# WAJIB diganti dengan string acak panjang & rahasia sebelum go-live.
# Bisa generate dengan: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti-dengan-string-rahasia-acak-minimal-48-karakter

JWT_EXPIRES_IN=8h

# Bisa lebih dari satu origin, dipisah koma (tanpa spasi setelah koma opsional, akan di-trim).
# Isi dengan URL frontend Vercel Anda (production + preview jika perlu).
FRONTEND_URL=https://nama-app-anda.vercel.app

# Jika menggunakan Railway Volume, arahkan ke path mount volume tersebut, misalnya /data.
# Jika tidak diset, default-nya ./data/damai.db (relatif terhadap folder backend).
DB_PATH=/data/damai.db
